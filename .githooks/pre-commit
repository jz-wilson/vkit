#!/usr/bin/env bash
# vkit pre-commit hook: gofmt + go vet + go test.
# Enable once per clone:  git config core.hooksPath .githooks
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# gofmt: fail if any staged *.go file is not formatted.
staged_go=$(git diff --cached --name-only --diff-filter=ACM -- '*.go')
if [ -n "$staged_go" ]; then
	unformatted=$(gofmt -l $staged_go)
	if [ -n "$unformatted" ]; then
		echo "pre-commit: gofmt needed on:" >&2
		echo "$unformatted" >&2
		echo "run: gofmt -w $unformatted" >&2
		exit 1
	fi
fi

echo "pre-commit: go vet ./..."
go vet ./...

echo "pre-commit: go test ./..."
go test ./...

echo "pre-commit: ok"
